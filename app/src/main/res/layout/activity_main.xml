<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/soundGridBackground"
    android:visibility="visible"
    tools:context=".MainActivity"
    tools:visibility="visible">

    <!-- Logo -->
    <ImageView
        android:id="@+id/imageViewLogo"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="32dp"
        android:contentDescription="@string/app_name"
        android:src="@drawable/ic_logo"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Responsive RecyclerView for sound items -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewSounds"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        android:background="?attr/soundGridBackground"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/textViewTimer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imageViewLogo"
        tools:listitem="@layout/sound_item" />

    <!-- Timer display -->
    <TextView
        android:id="@+id/textViewTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:textColor="?attr/timerTextColor"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/linearLayoutControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="00:00"
        tools:visibility="visible" />

    <!-- Control buttons: Play/Pause, Clear, Timer -->
    <LinearLayout
        android:id="@+id/linearLayoutControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/buttonPlayPause"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/play_pause"
            android:padding="16dp"
            android:src="@drawable/ic_play"
            android:scaleType="fitCenter"
            app:tint="?attr/controlIconColor" />

        <ImageButton
            android:id="@+id/buttonClear"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/clear"
            android:padding="16dp"
            android:src="@drawable/ic_clear"
            android:scaleType="fitCenter"
            app:tint="?attr/controlIconColor" />

        <ImageButton
            android:id="@+id/buttonTimer"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/set_timer"
            android:padding="16dp"
            android:src="@drawable/ic_timer"
            android:scaleType="fitCenter"
            app:tint="?attr/controlIconColor" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>