<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Custom attributes for styling components -->
    <attr name="controlIconColor" format="color" />
    <attr name="soundGridBackground" format="color" />
    <attr name="soundItemBackground" format="color" />
    <attr name="timerTextColor" format="color" />
    <attr name="timerTextColorOnBackground" format="color" />

    <!-- Base application theme -->
    <style name="Theme.Naturo" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Background colors -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/on_surface</item>
        <item name="android:textColorSecondary">@color/on_background</item>

        <!-- Custom theme attributes -->
        <item name="controlIconColor">@color/control_icon_light</item>
        <item name="soundGridBackground">@color/sound_grid_background_light</item>
        <item name="soundItemBackground">@color/sound_item_active</item>
        <item name="timerTextColor">@color/timer_text</item>
        <item name="timerTextColorOnBackground">@color/on_timer_text</item>

        <!-- Widget styles -->
        <item name="buttonStyle">@style/Widget.Naturo.Button</item>
        <item name="switchStyle">@style/Widget.Naturo.Switch</item>
        <item name="cardViewStyle">@style/Widget.Naturo.Card</item>
    </style>
</resources>